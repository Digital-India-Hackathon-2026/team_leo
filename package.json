{
  "name": "personacode-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @personacode/server dev",
    "dev:mock": "pnpm --filter @personacode/server dev:mock",
    "dev:web": "pnpm --filter @personacode/web dev",
    "dev:channels": "pnpm --filter @personacode/channels dev",
    "cli": "pnpm --filter @personacode/cli start",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
