    "dev:mock": "cross-env PERSONACODE_MOCK=1 tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@personacode/contracts": "workspace:*",
    "@personacode/core": "workspace:*",
    "ai": "^7.0.18",
    "dotenv": "^17.4.2",
    "hono": "^4.12.28"
  }
}
