# Personacode provider keys — copy to .env and fill in what you have.
# Every provider below has a free tier with no credit card. Get keys via `/connect`
# in the CLI, the web Connect page, or docs/pre-hackathon-checklist.md.
# The server proxies ALL LLM calls; keys never reach the web client.

# 1. Google AI Studio — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# 2. Groq — https://console.groq.com/keys
GROQ_API_KEY=

# 3. Cerebras — https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# 4. OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# 5. NVIDIA NIM — https://build.nvidia.com/
NVIDIA_API_KEY=

# 6. GitHub Models — https://github.com/settings/tokens (fine-grained PAT)
GITHUB_MODELS_TOKEN=

# 7. OpenCode Zen — https://opencode.ai/zen
OPENCODE_ZEN_API_KEY=

# 8. Ollama (local, optional) — https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Channels (Dev C) ---
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_USER=
EMAIL_APP_PASSWORD=

# --- Server ---
PERSONACODE_PORT=3789
# Set to 1 to run without any provider keys (canned streaming responses)
PERSONACODE_MOCK=
